{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/WebAppDevResult",
  "definitions": {
    "WebAppDevResult": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "Proxy server URL (where user should open browser)"
        },
        "devServerUrl": {
          "type": "string",
          "description": "Dev server URL being proxied"
        }
      },
      "required": ["url", "devServerUrl"],
      "additionalProperties": false,
      "description": "Command execution result What the sf multi-framework dev command returns to the user"
    }
  }
}
